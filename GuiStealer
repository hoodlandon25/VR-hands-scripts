local function startTappingPhase()
	currentStep = 3
	contentText.Text = "Step 2/3: Touch targeting active.\n\nTarget GUI: [" .. targetGui.Name .. "]\n\nTap on any part of the GUI to highlight, or click SKIP to generate immediately."
	
	-- Half-width button alignments
	skipBtn.Visible = true
	actionBtn.Size = UDim2.new(0, 140, 0, 35)
	actionBtn.Position = UDim2.new(1, -150, 1, -45)
	actionBtn.Text = "Waiting..."
	actionBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	actionBtn.Active = false

	-- Setup touch hooks on the detected GUI descendants
	local function hookElements()
		cleanHookConnections()
		for _, obj in ipairs(targetGui:GetDescendants()) do
			if obj:IsA("GuiObject") then
				local conn = obj.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
						selectedElement = obj
						highlightFrame.Parent = obj -- Outline the selected element
						
						contentText.Text = "Step 3/3: Bounding-box locked on [" .. obj.Name .. "]\n\nPress OK below to generate the code logs, or click SKIP."
						actionBtn.Text = "OK"
						actionBtn.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
						actionBtn.Active = true
					end
				end)
				table.insert(hookConnections, conn)
			end
		end
	end
	hookElements()
end

local function startWatchingPhase()
	currentStep = 2
	contentText.Text = "Step 1/3: Watching for executions...\n\nExecute your other GUI script now. We will monitor the background."
	actionBtn.Text = "NEXT"
	actionBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 220)
	actionBtn.Active = true

	-- Connection detectors
	local function onChildAdded(child)
		if child:IsA("ScreenGui") and child.Name ~= "NovolineDecompiler" then
			-- Ensure unique registry
			local alreadyAdded = false
			for _, g in ipairs(detectedGuis) do
				if g == child then alreadyAdded = true break end
			end
			
			if not alreadyAdded then
				table.insert(detectedGuis, child)
				targetGui = child -- Default to most recently loaded GUI

				local names = {}
				for _, g in ipairs(detectedGuis) do
					table.insert(names, g.Name)
				end
				contentText.Text = "Step 1/3: Watching for executions...\n\nCurrently Detected:\n" .. table.concat(names, ", ") .. "\n\nExecute more scripts, or click NEXT when ready."
			end
		end
	end

	scanCore = CoreGui.ChildAdded:Connect(onChildAdded)
	scanPlayer = playerGui.ChildAdded:Connect(onChildAdded)
end

