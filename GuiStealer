		if #detectedGuis > 0 then
			if scanCore then scanCore:Disconnect() end
			if scanPlayer then scanPlayer:Disconnect() end
			startTappingPhase()
		else
			contentText.Text = "Step 1/3: Watching for executions...\n\n❌ No GUIs detected yet! Please execute your other script first."
