local function serializeValue(val)
	if type(val) == "string" then
		return '"' .. val .. '"'
	elseif type(val) == "number" or type(val) == "boolean" then
		return tostring(val)
	elseif typeof(val) == "Color3" then
		return "Color3.fromRGB(" .. math.round(val.R*255) .. ", " .. math.round(val.G*255) .. ", " .. math.round(val.B*255) .. ")"
	elseif typeof(val) == "UDim2" then
		return "UDim2.new(" .. val.X.Scale .. ", " .. val.X.Offset .. ", " .. val.Y.Scale .. ", " .. val.Y.Offset .. ")"
	elseif typeof(val) == "UDim" then
		return "UDim.new(" .. val.Scale .. ", " .. val.Offset .. ")"
	elseif typeof(val) == "Vector2" then
		return "Vector2.new(" .. val.X .. ", " .. val.Y .. ")"
	elseif typeof(val) == "EnumItem" then
		return tostring(val)
	end
	return nil
end

-- Scan locations for non-system ScreenGuis
local function getScreenGuis()
	local guis = {}
	local locations = {CoreGui, playerGui}
	for _, loc in ipairs(locations) do
		if loc then
			for _, child in ipairs(loc:GetChildren()) do
				if child:IsA("ScreenGui") and child.Name ~= "NovolineDecompiler" then
					table.insert(guis, child)
				end
			end
		end
	end
	return guis
end

-- Decompiler Engine
local function decompileGui(targetGui)
	local code = {"-- Generated with Novoline UI Decompiler", "local gui = Instance.new(\"ScreenGui\")", "gui.Name = \"" .. targetGui.Name .. "\"", "gui.ResetOnSpawn = false", "gui.Parent = game:GetService(\"CoreGui\") or game:GetService(\"Players\").LocalPlayer:WaitForChild(\"PlayerGui\")", ""}
	local varMap = {}
	local varCount = 0

	local function getVarName(inst)
		if inst == targetGui then return "gui" end
		varCount = varCount + 1
		return inst.ClassName .. "_" .. varCount
	end

	local function processInstance(inst, parentVar)
		local myVar = getVarName(inst)
		varMap[inst] = myVar

		if inst ~= targetGui then
			table.insert(code, "local " .. myVar .. ' = Instance.new("' .. inst.ClassName .. '")')
		end

		local props = {}
		for _, p in ipairs(propertiesToDump.Common) do
			pcall(function() props[p] = inst[p] end)
		end

		local classProps = propertiesToDump[inst.ClassName]
		if classProps then
			for _, p in ipairs(classProps) do
				pcall(function() props[p] = inst[p] end)
			end
		end

		for k, v in pairs(props) do
			if k ~= "Name" or inst ~= targetGui then -- skip ScreenGui renaming
				local sVal = serializeValue(v)
				if sVal then
					table.insert(code, myVar .. "." .. k .. " = " .. sVal)
				end
			end
		end

		if parentVar and inst ~= targetGui then
			table.insert(code, myVar .. ".Parent = " .. parentVar)
		end
		table.insert(code, "")

		for _, child in ipairs(inst:GetChildren()) do
			processInstance(child, myVar)
		end
	end

	processInstance(targetGui, nil)
	return table.concat(code, "\n")
end

