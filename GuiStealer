-- Dragging logic
local dragging, dragInput, dragStart, startPos
topBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end
end)
UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

-- Main UI Refresh Logic
local function refresh()
	for _, child in ipairs(listFrame:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	
	local guis = getScreenGuis()
	local count = 0
	for _, guiInstance in ipairs(guis) do
		count = count + 1
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(1, -6, 0, 28)
		btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
		btn.Font = Enum.Font.GothamBold
		btn.Text = "  " .. guiInstance.Name .. " (" .. tostring(#guiInstance:GetDescendants()) .. " Elements)"
		btn.TextColor3 = Color3.fromRGB(200, 200, 200)
		btn.TextSize = 10
		btn.TextXAlignment = Enum.TextXAlignment.Left
		btn.Parent = listFrame

		local c = Instance.new("UICorner")
		c.CornerRadius = UDim.new(0, 4)
		c.Parent = btn

		btn.Activated:Connect(function()
			btn.Text = "⚡ Decompiling..."
			btn.TextColor3 = Color3.fromRGB(0, 180, 255)
			task.wait(0.1)
			
			local success, resultCode = pcall(function()
				return decompileGui(guiInstance)
			end)

			if success and setclipboard then
				setclipboard(resultCode)
				btn.Text = "✅ Code Copied to Clipboard!"
				btn.TextColor3 = Color3.fromRGB(100, 255, 100)
			else
				btn.Text = "❌ Decompile/Clipboard Failed"
				btn.TextColor3 = Color3.fromRGB(255, 100, 100)
			end
			task.wait(2)
			refresh()
		end)
	end
	listFrame.CanvasSize = UDim2.new(0, 0, 0, count * 32)
end

